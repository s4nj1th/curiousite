<span id="pi" class="inline"></span>

<script>
const container = document.getElementById("pi");

let chunkIndex = 0;
let loading = false;

async function loadChunk() {
    if (loading || !container) return;
    loading = true;

    const file = `/pi/chunk-${String(chunkIndex).padStart(4,"0")}.txt`;

    try {
        const res = await fetch(file);

        if (!res.ok) {
            console.log("No more chunks");
            loading = false;
            return;
        }

        const text = await res.text();

        const span = document.createElement("span");
        span.textContent = text.replace(/\n/g,"");

        container.appendChild(span);

        chunkIndex++;

        /* prevent DOM from growing infinitely */
        if (container.children.length > 40) {
            container.removeChild(container.firstChild);
        }

    } catch (err) {
        console.error("Chunk load error:", err);
    } finally {
        loading = false;
    }
}

window.addEventListener("scroll", () => {

    const bottom =
        window.innerHeight + window.scrollY >=
        document.body.offsetHeight - 800;

    if (bottom) loadChunk();

});

/* initial load */
loadChunk();
loadChunk();
</script>
