---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Mandelbrot Explorer | Curiousite">
    <div class="mb-8 transition-colors duration-200">
        <h1 class="text-3xl font-semibold text-accent mb-2">
            Mandelbrot Explorer
        </h1>
        <p class="text-fg-muted text-sm">
            Use your mouse to explore the fractal boundaries.
        </p>
    </div>

    <div
        class="w-full aspect-square sm:aspect-video rounded-xl border border-border-subtle bg-bg-secondary overflow-hidden relative cursor-crosshair transition-colors duration-200"
    >
        <canvas id="mandelbrot" class="w-full h-full block"></canvas>
    </div>

    <script>
        const canvas = document.getElementById(
            "mandelbrot",
        ) as HTMLCanvasElement;
        const ctx = canvas.getContext("2d")!;

        // Maintain square coordinates regardless of container aspect ratio
        let width = 0;
        let height = 0;
        let pixelRatio = 1;

        let zoom = 200;
        let offsetX = 0;
        let offsetY = 0;

        let isDragging = false;
        let lastX = 0;
        let lastY = 0;

        // Track time to prevent blocking main thread on high-res screens
        let drawTimeout: number | null = null;

        function resize() {
            const rect = canvas.parentElement!.getBoundingClientRect();
            width = rect.width;
            height = rect.height;

            // Scale canvas internal resolution to prevent blurriness on high-DPI displays
            pixelRatio = window.devicePixelRatio || 1;
            canvas.width = Math.floor(width * pixelRatio);
            canvas.height = Math.floor(height * pixelRatio);

            // Initial scaling to fit the Mandelbrot set (typically x: [-2.5, 1], y: [-1.5, 1.5])
            const mathWidth = 3.5;
            const mathHeight = 3.0;

            const zoomX = width / mathWidth;
            const zoomY = height / mathHeight;
            zoom = Math.min(zoomX, zoomY);

            // Center the set initially
            offsetX = -0.75 - width / (2 * zoom);
            offsetY = -(height / (2 * zoom));

            queueDraw();
        }

        function queueDraw() {
            if (!drawTimeout) {
                drawTimeout = window.requestAnimationFrame(() => {
                    draw();
                    drawTimeout = null;
                });
            }
        }

        function draw() {
            const physicalWidth = canvas.width;
            const physicalHeight = canvas.height;
            const imgData = ctx.createImageData(physicalWidth, physicalHeight);
            const data = imgData.data;

            for (let x = 0; x < physicalWidth; x++) {
                for (let y = 0; y < physicalHeight; y++) {
                    let cx = x / pixelRatio / zoom + offsetX;
                    let cy = y / pixelRatio / zoom + offsetY;
                    let zx = 0;
                    let zy = 0;
                    let i = 0;
                    const maxI = 100;

                    while (zx * zx + zy * zy < 4 && i < maxI) {
                        let temp = zx * zx - zy * zy + cx;
                        zy = 2 * zx * zy + cy;
                        zx = temp;
                        i++;
                    }

                    let p = (x + y * physicalWidth) * 4;

                    if (i === maxI) {
                        // Inside the set: color it black
                        data[p] = 0;
                        data[p + 1] = 0;
                        data[p + 2] = 0;
                        data[p + 3] = 255;
                    } else {
                        // Smooth iteration count to avoid color banding
                        let log_zn = Math.log(zx * zx + zy * zy) / 2;
                        let nu = Math.log(log_zn / Math.LN2) / Math.LN2;
                        let iter = i + 1 - nu;

                        // Vibrant smooth colorful mapping using sine waves offset by 120 degrees
                        data[p] = Math.sin(0.1 * iter + 0) * 127 + 128; // Red
                        data[p + 1] = Math.sin(0.1 * iter + 2.094) * 127 + 128; // Green
                        data[p + 2] = Math.sin(0.1 * iter + 4.188) * 127 + 128; // Blue
                        data[p + 3] = 255;
                    }
                }
            }
            ctx.putImageData(imgData, 0, 0);
        }

        window.addEventListener("resize", resize);

        // Pan (Drag) Implementation
        canvas.addEventListener("mousedown", (e) => {
            isDragging = true;
            lastX = e.clientX;
            lastY = e.clientY;
            canvas.style.cursor = "grabbing";
        });

        window.addEventListener("mouseup", () => {
            isDragging = false;
            canvas.style.cursor = "crosshair";
        });

        window.addEventListener("mousemove", (e) => {
            if (!isDragging) return;

            const dx = e.clientX - lastX;
            const dy = e.clientY - lastY;

            // Note: moving mouse right effectively shifts the view window left,
            // so we *subtract* the delta scaled down by zoom.
            // dx is CSS pixels. The distance in math plane is dx / zoom;
            offsetX -= dx / zoom;
            offsetY -= dy / zoom;

            lastX = e.clientX;
            lastY = e.clientY;

            queueDraw();
        });

        // Zoom (Scroll Wheel) Implementation
        canvas.addEventListener(
            "wheel",
            (e) => {
                e.preventDefault();

                const rect = canvas.getBoundingClientRect();
                const mouseX = e.clientX - rect.left;
                const mouseY = e.clientY - rect.top;

                // Record math coordinates under the mouse before zooming
                const mathX = mouseX / zoom + offsetX;
                const mathY = mouseY / zoom + offsetY;

                const zoomFactor = e.deltaY > 0 ? 0.8 : 1.25;
                zoom *= zoomFactor;

                // Adjust offsets to keep the math coordinate fixed under the mouse cursor
                offsetX = mathX - mouseX / zoom;
                offsetY = mathY - mouseY / zoom;

                queueDraw();
            },
            { passive: false },
        );

        resize(); // Trigger initial sizing and draw
    </script>
</BaseLayout>
